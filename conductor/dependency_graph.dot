digraph KijkoDependencyGraph {
  rankdir=TB;
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=11];
  edge [color="#868e96", arrowsize=0.8];
  graph [label="Kijko: PTY Migration Dependency Graph", labelloc=t, fontsize=16, fontname="Helvetica Bold"];

  // Entry Point
  subgraph cluster_entry {
    label="Entry Point";
    style=filled; color="#e1f5ff";
    extension [label="extension.ts\n(hub)", fillcolor="#4dabf7", fontcolor=white];
  }

  // UI / View Layer
  subgraph cluster_ui {
    label="Presentation Layer";
    style=filled; color="#fff3e0";
    webviewProvider [label="webviewProvider.ts", fillcolor="#ffb74d"];
    chatPanel [label="chatPanel.ts", fillcolor="#ffb74d"];
  }

  // Core Domain
  subgraph cluster_claude {
    label="Core Domain (claude/)";
    style=filled; color="#e8f5e9";
    claudeProcess [label="claudeProcess.ts", fillcolor="#66bb6a", fontcolor=white];
    conductor_mod [label="conductor.ts", fillcolor="#66bb6a", fontcolor=white];
    ralph [label="ralph.ts", fillcolor="#66bb6a", fontcolor=white];
    types [label="types.ts", fillcolor="#a5d6a7"];
  }

  // Managers
  subgraph cluster_managers {
    label="Services";
    style=filled; color="#f3e5f5";
    agentManager [label="agentManager.ts", fillcolor="#ba68c8", fontcolor=white];
    cliManager [label="cliManager.ts", fillcolor="#ba68c8", fontcolor=white];
  }

  // Detection
  subgraph cluster_detection {
    label="Detection / Integration";
    style=filled; color="#fce4ec";
    cliDetector [label="cliDetector.ts", fillcolor="#ef9a9a"];
    conductorIntegration [label="conductorIntegration.ts", fillcolor="#ef9a9a"];
    taskDetector [label="taskDetector.ts", fillcolor="#ef9a9a"];
  }

  // Utility
  subgraph cluster_utility {
    label="Utility";
    style=filled; color="#f5f5f5";
    streamParser [label="streamParser.ts", fillcolor="#e0e0e0"];
  }

  // NEW PTY FILES
  subgraph cluster_pty {
    label="NEW: PTY Architecture";
    style="filled,bold"; color="#fffde7"; penwidth=3;
    ptyManager [label="ptyManager.ts\n(node-pty spawn)", fillcolor="#fff176", style="rounded,filled,bold"];
    coldPathProcessor [label="coldPathProcessor.ts\n(async processing)", fillcolor="#fff176", style="rounded,filled,bold"];
    claudeTerminal [label="claudeTerminal.ts\n(Pseudoterminal)", fillcolor="#ffd54f", style="rounded,filled,bold"];
    oauthRefresh [label="oauthRefresh.ts\n(token refresh)", fillcolor="#fff176", style="rounded,filled,bold"];
  }

  // EXISTING EDGES
  extension -> agentManager;
  extension -> webviewProvider;
  extension -> conductorIntegration;
  extension -> taskDetector;
  extension -> cliDetector;
  extension -> conductor_mod;
  extension -> ralph;
  extension -> chatPanel;
  agentManager -> chatPanel;
  agentManager -> types;
  chatPanel -> cliManager;
  chatPanel -> cliDetector;
  cliManager -> streamParser;
  webviewProvider -> agentManager;
  webviewProvider -> conductorIntegration;
  taskDetector -> conductorIntegration;
  taskDetector -> agentManager;
  claudeProcess -> streamParser;
  claudeProcess -> types;
  conductor_mod -> claudeProcess;
  conductor_mod -> agentManager;
  conductor_mod -> types;
  ralph -> claudeProcess;
  ralph -> agentManager;
  ralph -> types;

  // NEW PTY EDGES
  extension -> claudeTerminal [style=bold, color="#f57f17", penwidth=2.5, label="register"];
  claudeTerminal -> ptyManager [style=bold, color=red, penwidth=3, label="HOT PATH"];
  claudeTerminal -> coldPathProcessor [style=dashed, color="#f57f17", label="tee (cold)"];
  claudeTerminal -> oauthRefresh [color="#f57f17", label="auth"];
  chatPanel -> oauthRefresh [color="#f57f17", label="auth"];

  // LEGEND
  subgraph cluster_legend {
    label="Legend"; style=filled; color=white;
    node [shape=plaintext];
    legend [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
        <TR><TD COLSPAN="2" BGCOLOR="#f5f5f5"><B>Architecture</B></TD></TR>
        <TR><TD BGCOLOR="#4dabf7"><FONT COLOR="white">Existing</FONT></TD><TD>Current codebase</TD></TR>
        <TR><TD BGCOLOR="#fff176">New (PTY)</TD><TD>PTY migration files</TD></TR>
        <TR><TD BGCOLOR="white"><FONT COLOR="red">━━━</FONT></TD><TD>Hot path (zero-copy)</TD></TR>
        <TR><TD BGCOLOR="white"><FONT COLOR="#f57f17">- - -</FONT></TD><TD>Cold path (async)</TD></TR>
      </TABLE>
    >];
  }
}
