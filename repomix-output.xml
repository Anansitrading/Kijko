    geminiApiKey: '',
    backendUrl: 'https://3001-iaxx0o3ruogtmyukx6kam-6532622b.e2b.dev',
    openaiApiKey: '',
    anthropicApiKey: '',
    elevenLabsApiKey: ''
  });
  const messagesEndRef = useRef<HTMLDivElement>(null);

  const scrollToBottom = () => {
